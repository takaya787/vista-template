# Plan files are ephemeral — only keep the directory structure
.ai/plans/*
!.ai/plans/.gitkeep

# Vista state and profile (generated per user, not shared)
.vista/state/
.vista/profile/

# Notion browser auth state (contains session cookies)
.notion-auth.json

# AI-generated documents (reports, planning, weekly-updates, etc.)
docs/planning/
docs/weekly-updates/
docs/sprint-goals/
docs/sprint-history/
docs/reports/

# Meeting transcripts (sensitive content)
minutes/*
!minutes/.gitkeep

# Assets (screenshots, videos, traces — all generated)
assets/

# Legacy screenshots directory
screenshots/

# Session logs (personal data)
.ai/session-logs/

# E2E test artifacts (Playwright)
test-results/

# Dependencies
node_modules/

# --- injected claude context ---
.claude/*
# --- injected claude context ---
