{
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "enableAllProjectMcpServers": true,
  "allowedTools": ["mcp__taskmaster-ai__*"],
  "plansDirectory": ".ai/plans",
  "permissions": {
    "allow": [
      "Bash(python3 ~/.claude/skills/recall-context/scripts/query_history.py:*)",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-python-rules.sh\":*)",
      "Bash(ls:*)",
      "Bash(test:*)",
      "Bash(head:*)",
      "WebSearch",
      "Edit(file_path:$CLAUDE_PROJECT_DIR/docs/*)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/docs/*)",
      "Read(file_path:$CLAUDE_PROJECT_DIR/docs/*)",
      "Edit(file_path:$CLAUDE_PROJECT_DIR/.ai/tasks/*)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/.ai/tasks/*)",
      "Edit(file_path:$CLAUDE_PROJECT_DIR/.claude/rules/config/*.md)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/.claude/rules/config/*.md)",
      "Read(file_path:$CLAUDE_PROJECT_DIR/.claude/rules/config/*.md)",

      "Edit(file_path:$CLAUDE_PROJECT_DIR/CLAUDE.md)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/CLAUDE.md)",

      "Edit(file_path:$CLAUDE_PROJECT_DIR/.ai/workflows/*.md)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/.ai/workflows/*.md)",
      "Read(file_path:$CLAUDE_PROJECT_DIR/.ai/workflows/*.md)",

      "Write(file_path:$CLAUDE_PROJECT_DIR/.vista/*.json)",
      "Edit(file_path:$CLAUDE_PROJECT_DIR/.vista/*.json)",
      "mcp__taskmaster-ai__*"
    ],
    "deny": [
      "Edit(file_path:$CLAUDE_PROJECT_DIR/.claude/rules/convention/*.md)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/.claude/rules/convention/*.md)",

      "Bash(sudo:*)",
      "Bash(su :*)",
      "Bash(su -:*)",

      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(shred:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",

      "Bash(curl*|*sh:*)",
      "Bash(wget*|*sh:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",

      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown:*)",

      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",

      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-no-branch.sh\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-python-rules.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-launchagent-cp.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit-file-write.sh\""
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-ssrf.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/audit-command.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__taskmaster-ai__(add_task|expand_task)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-manifest-on-task.sh\""
          }
        ]
      }
    ],
    "Notification": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.vista/bin/vista-sync-history\""
          }
        ]
      }
    ]
  }
}
