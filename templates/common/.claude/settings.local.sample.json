{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(test:*)",
      "Bash(head:*)",
      "WebSearch",
      "Bash(bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify.sh\":*)",
      "Edit(file_path:$CLAUDE_PROJECT_DIR/docs/*)",
      "Write(file_path:$CLAUDE_PROJECT_DIR/docs/*)",
      "Read(file_path:$CLAUDE_PROJECT_DIR/docs/*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "plansDirectory": ".ai/plans"
}
